{
  "name": "tailtown",
  "version": "0.1.0",
  "description": "Pet Resort Management System for Tailtown",
  "private": true,
  "scripts": {
    "dev": "turbo dev --ui tui",
    "build": "pnpm -r run build",
    "env:setup": "./scripts/create-env-files-based-on-examples.sh",
    "env:copy": "./scripts/copy-main-worktree-env-files.sh",
    "db:setup": "pnpm run prisma:migrate && pnpm run prisma:generate",
    "prisma:migrate": "pnpm -r --filter \"./apps/*-service\" run --if-present prisma:migrate",
    "prisma:generate": "pnpm -r --filter \"./apps/*-service\" run --if-present prisma:generate",
    "format:write": "prettier --write \"**/*.{ts,tsx,html,js,jsx,jsonc,json,astro,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,html,js,jsx,jsonc,json,astro,mdx}\" --cache",
    "test:notifications": "node scripts/test-notifications.js",
    "test": "pnpm -r run test",
    "test:integration": "pnpm -r --if-present run test:integration",
    "test:services": "pnpm --filter @tailtown/e2e run smoke",
    "test:e2e": "turbo run e2e --filter=@tailtown/e2e",
    "test:e2e:ui": "turbo run e2e:ui --filter=@tailtown/e2e",
    "test:e2e:headed": "turbo run e2e:headed --filter=@tailtown/e2e",
    "test:e2e:debug": "turbo run e2e:debug --filter=@tailtown/e2e",
    "test:e2e:report": "turbo run e2e:report --filter=@tailtown/e2e",
    "test:builds": "bash scripts/test-builds.sh",
    "test:typescript": "bash scripts/test-typescript.sh",
    "test:builds:full": "bash scripts/test-builds.sh --include-frontend",
    "test:typescript:full": "bash scripts/test-typescript.sh --include-frontend",
    "test:perf": "./performance/run-all-tests.sh",
    "test:perf:load": "k6 run performance/reservation-load-test.js",
    "test:perf:concurrent": "k6 run performance/concurrent-booking-test.js",
    "test:perf:db": "k6 run performance/database-query-test.js",
    "coverage": "./scripts/generate-coverage-report.sh",
    "coverage:badge": "node scripts/coverage-badge.js",
    "coverage:open": "open apps/frontend/coverage/lcov-report/index.html && open apps/reservation-service/coverage/lcov-report/index.html",
    "import:staff": "node scripts/import-staff-data.js",
    "import:staff:gingr": "node scripts/import-staff-data.js gingr",
    "import:staff:csv": "node scripts/import-staff-data.js csv",
    "import:staff:json": "node scripts/import-staff-data.js json",
    "hash:password": "node scripts/import-staff-data.js hash-password"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.31.0"
  },
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "chromedriver": "139.0.0",
    "lerna": "6.6.2",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "puppeteer": "24.16.0",
    "selenium-webdriver": "4.34.0",
    "turbo": "2.8.17",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@emotion/react": "11.11.1",
    "@mui/icons-material": "5.14.19",
    "@mui/material": "5.14.20",
    "@mui/system": "5.14.20",
    "@types/react": "18.2.64",
    "@types/react-dom": "18.2.21",
    "bcrypt": "6.0.0",
    "csv-parse": "6.1.0",
    "pg": "8.16.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "eslint": "8.57.1"
  }
}
