# Consolidated app environment variables example.
# Shared values are namespaced by group, and app-specific values are namespaced by app.

# -*********************************************************-
# Services
# -*********************************************************-

# Shared services runtime/build vars
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
DATABASE_SSL_ENABLED=false
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT=10000
REDIS_URL=redis://localhost:6379
PASSWORD_SALT_ROUNDS=12
LOG_LEVEL=info

# Customer Service
CUSTOMER_SERVICE_PORT=4004
CUSTOMER_SERVICE_HOST=0.0.0.0
CUSTOMER_SERVICE_TRUST_PROXY=false
CUSTOMER_SERVICE_DISABLE_HTTPS_REDIRECT=true
CUSTOMER_SERVICE_DATA_DIR=./data
CUSTOMER_DATABASE_URL="postgresql://username:password@localhost:5432/tailtown_customer?schema=public"
CUSTOMER_JWT_SECRET="replace_with_secure_random_string"
CUSTOMER_JWT_EXPIRES_IN="8h"
CUSTOMER_JWT_REFRESH_SECRET="replace_with_different_secure_random_string"
CUSTOMER_JWT_REFRESH_EXPIRES_IN="7d"
CUSTOMER_JWT_REFRESH_TOKEN_EXPIRES_IN="7d"
CUSTOMER_SUPER_ADMIN_JWT_SECRET="replace_with_another_secure_random_string"
CUSTOMER_SUPER_ADMIN_JWT_EXPIRES_IN="8h"
CUSTOMER_SUPER_ADMIN_REFRESH_EXPIRES_IN="7d"
CUSTOMER_BCRYPT_ROUNDS=12
CUSTOMER_SESSION_SECRET="replace_with_secure_session_secret"
CUSTOMER_ENABLE_2FA=false
CUSTOMER_SUPER_ADMIN_API_KEY="replace_with_secure_random_api_key"
CUSTOMER_SERVICE_API_KEY="replace_with_secure_random_api_key"
CUSTOMER_ALLOWED_METHODS="GET,POST,PUT,DELETE,PATCH"
CUSTOMER_ALLOWED_HEADERS="Content-Type,Authorization"
CUSTOMER_ALLOW_CREDENTIALS=true
CUSTOMER_API_PREFIX="/api"
CUSTOMER_API_VERSION="v1"
CUSTOMER_ENABLE_API_DOCS=true
CUSTOMER_RATE_LIMIT_WINDOW=15
CUSTOMER_RATE_LIMIT_SKIP_TRUSTED=false
CUSTOMER_UPLOAD_PATH="./uploads"
CUSTOMER_UPLOAD_DIR="./uploads"
CUSTOMER_MAX_FILE_SIZE=5242880
CUSTOMER_ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"
CUSTOMER_SCAN_UPLOADS_FOR_MALWARE=false
CUSTOMER_LOG_FORMAT="text"
CUSTOMER_LOG_TO_FILE=false
CUSTOMER_LOG_FILE="./logs/customer-service.log"
CUSTOMER_LOG_FILE_PATH="./logs/customer-service.log"
CUSTOMER_REDIS_PASSWORD=""
CUSTOMER_CACHE_TTL=3600
CUSTOMER_SMTP_HOST="smtp.gmail.com"
CUSTOMER_SMTP_PORT=587
CUSTOMER_SMTP_USER="your-email@example.com"
CUSTOMER_SMTP_PASSWORD="your-app-specific-password"
CUSTOMER_FROM_EMAIL="noreply@example.com"
CUSTOMER_SENDGRID_API_KEY=""
CUSTOMER_SENDGRID_FROM_EMAIL="noreply@example.com"
CUSTOMER_SENDGRID_FROM_NAME="Tailtown"
CUSTOMER_ENABLE_METRICS=false
CUSTOMER_METRICS_PORT=9090
CUSTOMER_SENTRY_DSN=""

# Reservation Service
RESERVATION_SERVICE_PORT=4003
RESERVATION_SERVICE_HOST=localhost
RESERVATION_SERVICE_TRUST_PROXY=false
RESERVATION_DATABASE_URL="postgresql://username:password@localhost:5432/tailtown_reservation?schema=public"
RESERVATION_JWT_SECRET=your_jwt_secret_here
RESERVATION_JWT_EXPIRES_IN=24h
RESERVATION_JWT_REFRESH_TOKEN_EXPIRES_IN=7d
RESERVATION_SESSION_SECRET=your_session_secret_here
RESERVATION_SERVICE_TIMEOUT=5000
RESERVATION_SERVICE_MAX_RETRIES=3
RESERVATION_SERVICE_RETRY_DELAY_MS=1000
RESERVATION_REDIS_ENABLED=true
RESERVATION_REDIS_DEFAULT_TTL=300
RESERVATION_LOG_FILE=./logs/reservation-service.log
RESERVATION_SENTRY_DSN=
RESERVATION_DISABLE_ERROR_TRACKING=false
RESERVATION_DISABLE_ERROR_PERSISTENCE=false

# Payment Service
PAYMENT_SERVICE_PORT=4005
PAYMENT_CARDCONNECT_API_URL=https://fts-uat.cardconnect.com/cardconnect/rest
PAYMENT_CARDCONNECT_MERCHANT_ID=496160873888
PAYMENT_CARDCONNECT_USERNAME=testing
PAYMENT_CARDCONNECT_PASSWORD=testing123
PAYMENT_CARDCONNECT_SITE=fts-uat
PAYMENT_TENANT_ID=default-tenant
PAYMENT_JWT_SECRET=your-jwt-secret-key-change-in-production
PAYMENT_API_KEY=your-api-key-change-in-production
PAYMENT_LOG_LEVEL=debug

#  -********************* Testing *********************-

# Customer Service
CUSTOMER_TEST_DATABASE_URL="postgresql://username:password@localhost:5432/tailtown_customer_test"

# Reservation Service
RESERVATION_TEST_DATABASE_URL="postgresql://username:password@localhost:5432/reservation_test?schema=public"

# Payment Service
# ... variables for the test environment will go here. Remove this line when you added any.

# -*********************************************************-
# Web Clients
# -*********************************************************-

# Shared web client runtime/build vars
VITE_NODE_ENV=development
VITE_API_URL=http://localhost:4004
VITE_RESERVATION_API_URL=http://localhost:4003
VITE_API_TIMEOUT=30000
VITE_PAYMENT_SERVICE_URL=http://localhost:4005
VITE_CUSTOMER_SERVICE_URL=http://localhost:4004
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false
VITE_SENTRY_RELEASE=tailtown-frontend@1.0.0

# Frontend
FRONTEND_PORT=3000
FRONTEND_TENANT_ID=dev

# Legacy Frontend
LEGACY_FRONTEND_PORT=3000
LEGACY_FRONTEND_GENERATE_SOURCEMAP=true
LEGACY_FRONTEND_INLINE_RUNTIME_CHUNK=true
LEGACY_FRONTEND_IMAGE_INLINE_SIZE_LIMIT=10000
LEGACY_FRONTEND_SKIP_PREFLIGHT_CHECK=false
LEGACY_FRONTEND_API_VERSION=v1
LEGACY_FRONTEND_RETRY_ATTEMPTS=3
LEGACY_FRONTEND_RETRY_DELAY=1000
LEGACY_FRONTEND_TENANT_ID=your-tenant-id
LEGACY_FRONTEND_CSP_ENABLED=true
LEGACY_FRONTEND_HSTS_ENABLED=true
LEGACY_FRONTEND_AUTH_STORAGE_KEY=tailtown_auth
LEGACY_FRONTEND_REFRESH_TOKEN_KEY=tailtown_refresh
LEGACY_FRONTEND_SESSION_TIMEOUT=3600000
LEGACY_FRONTEND_ENABLE_DEBUG=false
LEGACY_FRONTEND_ENABLE_MOCK_DATA=false
LEGACY_FRONTEND_ENABLE_ERROR_REPORTING=true
LEGACY_FRONTEND_ENABLE_ANALYTICS=true
LEGACY_FRONTEND_ENABLE_NOTIFICATIONS=true
LEGACY_FRONTEND_ENABLE_SERVICE_WORKER=true
LEGACY_FRONTEND_THEME=light
LEGACY_FRONTEND_ITEMS_PER_PAGE=10
LEGACY_FRONTEND_DATE_FORMAT=MM/DD/YYYY
LEGACY_FRONTEND_TIME_FORMAT=HH:mm
LEGACY_FRONTEND_TIMEZONE=America/Denver
LEGACY_FRONTEND_CURRENCY=USD
LEGACY_FRONTEND_LANGUAGE=en-US
LEGACY_FRONTEND_ENABLE_COMPRESSION=true
LEGACY_FRONTEND_CACHE_MAX_AGE=86400
LEGACY_FRONTEND_ENABLE_PREFETCH=true
LEGACY_FRONTEND_ERROR_SAMPLE_RATE=0.1
LEGACY_FRONTEND_GA_TRACKING_ID=
LEGACY_FRONTEND_GOOGLE_ANALYTICS_ID=
LEGACY_FRONTEND_MIXPANEL_TOKEN=
LEGACY_FRONTEND_LAUNCH_DARKLY_KEY=
LEGACY_FRONTEND_PWA_NAME="Tailtown Pet Resort"
LEGACY_FRONTEND_PWA_SHORT_NAME="Tailtown"
LEGACY_FRONTEND_PWA_THEME_COLOR="#4c8bf5"
LEGACY_FRONTEND_PWA_BACKGROUND_COLOR="#ffffff"

#  -********************* Testing *********************-

# No web client testing variables are currently defined in the app-level `.env.example` files.
