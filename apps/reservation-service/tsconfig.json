{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "skipDefaultLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": "./src",
    "paths": {
      "*": ["*"]
    },
    "declaration": true,
    "noEmitOnError": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "src/tests/**/*",
    "**/__tests__/**/*"
  ]
}
