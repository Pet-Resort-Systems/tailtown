{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "strict": false,
    "noImplicitAny": false,
    "skipDefaultLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "declaration": true,
    "noEmitOnError": false
  },
  "include": ["src/**/*", "prisma.config.ts"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "src/tests/**/*",
    "**/__tests__/**/*"
  ]
}
