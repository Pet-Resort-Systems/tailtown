{
  "name": "@tailtown/reservation-service",
  "version": "1.0.0",
  "description": "Reservation management service for Tailtown",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "prebuild": "prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --config jest.integration.config.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@types/compression": "1.8.1",
    "axios": "1.13.6",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "express-rate-limit": "8.3.0",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.1",
    "pg": "8.16.3",
    "redis": "5.11.0",
    "uuid": "11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/cors": "2.8.13",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/multer": "2.1.0",
    "@types/node": "25.3.5",
    "@types/node-fetch": "2.6.13",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.3",
    "jest": "30.2.0",
    "prisma": "7.4.2",
    "supertest": "7.2.2",
    "ts-jest": "29.1.0",
    "ts-node-dev": "2.0.0",
    "typescript": "catalog:"
  }
}
