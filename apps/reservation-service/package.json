{
  "name": "@tailtown/reservation-service",
  "version": "0.1.0",
  "description": "Reservation management service for Tailtown",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsgo",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:tsgo": "tsgo --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --config jest.integration.config.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "@tailtown/ms-clone": "workspace:*",
    "@tailtown/shared": "workspace:*",
    "@types/compression": "1.8.1",
    "axios": "1.13.6",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "catalog:",
    "express-rate-limit": "catalog:",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.1",
    "pg": "8.16.3",
    "redis": "5.11.0",
    "uuid": "11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/cors": "2.8.13",
    "@types/express": "catalog:",
    "@types/express-serve-static-core": "catalog:",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/multer": "2.1.0",
    "@types/node": "catalog:",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@typescript/native-preview": "catalog:",
    "eslint": "10.0.3",
    "jest": "30.2.0",
    "prisma": "catalog:",
    "supertest": "7.2.2",
    "ts-jest": "29.1.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
