# Reservation Service Environment Variables
# Copy this file to .env and fill with your local values.

# Environment
NODE_ENV=development # development, test, production
PORT=4003
HOST=localhost
TRUST_PROXY=false

# Database
DATABASE_URL="postgresql://username:password@localhost:5433/reservation?schema=public"
TEST_DATABASE_URL="postgresql://username:password@localhost:5434/reservation_test?schema=public"
DATABASE_SSL_ENABLED=false
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT=10000

# Security / Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
SESSION_SECRET=your_session_secret_here
PASSWORD_SALT_ROUNDS=12

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# API Integration - Microservice Communication
CUSTOMER_SERVICE_URL=http://localhost:4004
SERVICE_TIMEOUT=5000
SERVICE_MAX_RETRIES=3
SERVICE_RETRY_DELAY_MS=1000

# Optional runtime settings
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
REDIS_DEFAULT_TTL=300
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=info
LOG_FILE=./logs/reservation-service.log
SENTRY_DSN=
DISABLE_ERROR_TRACKING=false
DISABLE_ERROR_PERSISTENCE=false
