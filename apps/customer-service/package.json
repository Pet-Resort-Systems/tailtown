{
  "name": "@tailtown/customer-service",
  "version": "0.1.0",
  "description": "Customer and pet management service for Tailtown Pet Resort",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "prisma generate && tsgo",
    "typecheck": "tsc --noEmit",
    "typecheck:tsgo": "tsgo --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit",
    "test:tenant-isolation": "jest tenant-isolation",
    "test:auth": "jest auth-flow",
    "test:schedule": "jest staff-schedule-overlap",
    "test:db:setup": "./scripts/setup-test-db.sh",
    "test:db:teardown": "./scripts/teardown-test-db.sh",
    "test:db:reset": "npm run test:db:teardown && npm run test:db:setup",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@sendgrid/mail": "8.1.6",
    "@sentry/node": "10.38.0",
    "@sentry/profiling-node": "10.42.0",
    "@tailtown/shared": "workspace:*",
    "@types/compression": "1.8.1",
    "bcrypt": "6.0.0",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "date-fns": "4.1.0",
    "dotenv": "17.3.1",
    "express": "catalog:",
    "express-rate-limit": "catalog:",
    "express-validator": "7.3.1",
    "helmet": "8.1.0",
    "morgan": "1.10.1",
    "multer": "2.1.1",
    "pg": "8.16.3",
    "redis": "5.11.0",
    "twilio": "5.12.2",
    "uuid": "13.0.0",
    "winston": "3.19.0",
    "zod": "4.3.6",
    "@t3-oss/env-core": "0.13.11"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/cors": "2.8.13",
    "@types/express": "catalog:",
    "@types/express-serve-static-core": "catalog:",
    "@types/helmet": "4.0.0",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/multer": "2.1.0",
    "@types/node": "catalog:",
    "@types/supertest": "6.0.3",
    "@types/twilio": "3.19.3",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.1",
    "@typescript/native-preview": "catalog:",
    "eslint": "10.0.3",
    "jest": "30.2.0",
    "prisma": "catalog:",
    "supertest": "7.2.2",
    "ts-jest": "29.1.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
