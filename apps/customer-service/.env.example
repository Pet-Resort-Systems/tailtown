# Customer Service Environment Variables
# Copy this file to .env and fill with your local values.

# Environment
NODE_ENV=development # development, test, production
PORT=4004
HOST=0.0.0.0
TRUST_PROXY=false
DISABLE_HTTPS_REDIRECT=true
DATA_DIR=./data

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/tailtown_customer"
DATABASE_SSL_ENABLED=false
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT=10000

# Authentication / JWT
JWT_SECRET="replace_with_secure_random_string"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_SECRET="replace_with_different_secure_random_string"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_TOKEN_EXPIRES_IN="7d"
SUPER_ADMIN_JWT_SECRET="replace_with_another_secure_random_string"
SUPER_ADMIN_JWT_EXPIRES_IN="8h"
SUPER_ADMIN_REFRESH_EXPIRES_IN="7d"

# Security
BCRYPT_ROUNDS=12
PASSWORD_SALT_ROUNDS=12
SESSION_SECRET="replace_with_secure_session_secret"
ENABLE_2FA=false

# API access keys
SUPER_ADMIN_API_KEY="replace_with_secure_random_api_key"
SERVICE_API_KEY="replace_with_secure_random_api_key"

# CORS / API
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
ALLOWED_METHODS="GET,POST,PUT,DELETE,PATCH"
ALLOWED_HEADERS="Content-Type,Authorization"
ALLOW_CREDENTIALS=true
API_PREFIX="/api"
API_VERSION="v1"
ENABLE_API_DOCS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=15
RATE_LIMIT_SKIP_TRUSTED=false

# Uploads
UPLOAD_PATH="./uploads"
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"
SCAN_UPLOADS_FOR_MALWARE=false

# Logging
LOG_LEVEL="info"
LOG_FORMAT="text"
LOG_TO_FILE=false
LOG_FILE="./logs/customer-service.log"
LOG_FILE_PATH="./logs/customer-service.log"

# Cache / Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
CACHE_TTL=3600

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-specific-password"
FROM_EMAIL="noreply@example.com"
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@example.com"
SENDGRID_FROM_NAME="Tailtown"

# Monitoring / Metrics
ENABLE_METRICS=false
METRICS_PORT=9090
SENTRY_DSN=""

# -*******************************************************************************-
# -****************************** TESTTING ***************************************-
# -*******************************************************************************-
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/tailtown_customer_test"
