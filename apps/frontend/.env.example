# Frontend Environment Variables
# Copy this file to .env and set values for your local environment.

NODE_ENV=development # development, test, production
# Dev server
PORT=3000

# API configuration
VITE_API_URL=http://localhost:4004
VITE_RESERVATION_API_URL=http://localhost:4003
VITE_API_TIMEOUT=30000

# Optional tenant override (normally inferred from subdomain/local storage)
VITE_TENANT_ID=dev

# Services
VITE_PAYMENT_SERVICE_URL=http://localhost:4005
VITE_CUSTOMER_SERVICE_URL=http://localhost:4004

# Error reporting (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false
VITE_SENTRY_RELEASE=tailtown-frontend@1.0.0
