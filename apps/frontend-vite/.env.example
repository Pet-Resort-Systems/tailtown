# Frontend Environment Variables
# Copy this file to .env and set values for your local environment.

# Build/runtime environment
NODE_ENV=development # development, test, production
PORT=3001
GENERATE_SOURCEMAP=true
INLINE_RUNTIME_CHUNK=true
IMAGE_INLINE_SIZE_LIMIT=10000
SKIP_PREFLIGHT_CHECK=false

# API configuration
REACT_APP_API_URL=http://localhost:4004
REACT_APP_RESERVATION_API_URL=http://localhost:4003
REACT_APP_API_TIMEOUT=30000
REACT_APP_API_VERSION=v1
REACT_APP_RETRY_ATTEMPTS=3
REACT_APP_RETRY_DELAY=1000

# Tenant / multi-tenancy
REACT_APP_TENANT_ID=your-tenant-id

# Security
REACT_APP_CSP_ENABLED=true
REACT_APP_HSTS_ENABLED=true
REACT_APP_AUTH_STORAGE_KEY=tailtown_auth
REACT_APP_REFRESH_TOKEN_KEY=tailtown_refresh
REACT_APP_SESSION_TIMEOUT=3600000

# Feature flags
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ENABLE_MOCK_DATA=false
REACT_APP_ENABLE_ERROR_REPORTING=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_SERVICE_WORKER=true

# UI / locale
REACT_APP_THEME=light
REACT_APP_ITEMS_PER_PAGE=10
REACT_APP_DATE_FORMAT=MM/DD/YYYY
REACT_APP_TIME_FORMAT=HH:mm
REACT_APP_TIMEZONE=America/Denver
REACT_APP_CURRENCY=USD
REACT_APP_LANGUAGE=en-US

# Performance
REACT_APP_ENABLE_COMPRESSION=true
REACT_APP_CACHE_MAX_AGE=86400
REACT_APP_ENABLE_PREFETCH=true

# Error reporting
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENABLED=false
REACT_APP_SENTRY_RELEASE=tailtown-frontend@1.0.0
REACT_APP_ERROR_SAMPLE_RATE=0.1

# Analytics / tracking
REACT_APP_GA_TRACKING_ID=
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_MIXPANEL_TOKEN=
REACT_APP_LAUNCH_DARKLY_KEY=

# PWA
REACT_APP_PWA_NAME="Tailtown Pet Resort"
REACT_APP_PWA_SHORT_NAME="Tailtown"
REACT_APP_PWA_THEME_COLOR="#4c8bf5"
REACT_APP_PWA_BACKGROUND_COLOR="#ffffff"

# Admin Portal (embedded in frontend-vite under /admin-portal)
VITE_CUSTOMER_SERVICE_URL=http://localhost:4004
