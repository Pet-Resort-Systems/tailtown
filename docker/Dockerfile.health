FROM node:24.14.0-alpine

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

WORKDIR /app

# Copy health check script and workspace metadata.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY scripts/health-check.js ./scripts/

# Install only production dependencies
# `...` means this package and its dependencies https://pnpm.io/filtering#--filter-package_name-1
RUN pnpm install --prod --frozen-lockfile

# Run health check every 5 minutes
CMD ["sh", "-c", "while true; do node scripts/health-check.js; sleep 300; done"]
