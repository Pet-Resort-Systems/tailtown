{
  "name": "@tailtown/customer-service",
  "version": "0.1.0",
  "description": "Customer and pet management service for Tailtown Pet Resort",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit",
    "test:tenant-isolation": "jest tenant-isolation",
    "test:auth": "jest auth-flow",
    "test:schedule": "jest staff-schedule-overlap",
    "test:db:setup": "./scripts/setup-test-db.sh",
    "test:db:teardown": "./scripts/teardown-test-db.sh",
    "test:db:reset": "npm run test:db:teardown && npm run test:db:setup",
    "lint": "eslint . --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.30.0",
    "@sentry/profiling-node": "^10.32.1",
    "@types/compression": "^1.8.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "redis": "^5.10.0",
    "twilio": "^5.11.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^6.0.3",
    "@types/twilio": "^3.19.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "prisma": "7.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
